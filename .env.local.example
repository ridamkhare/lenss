# Either of these unlocks real model output. Without one, the app
# returns hand-crafted mock readings so the UI works offline.

# OpenRouter — gateway to many providers under one key.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model for reveal and compare. Can be any OpenRouter model id,
# including the ":free" tier. Defaults to anthropic/claude-sonnet-4.5
# if unset.
OPENROUTER_MODEL=

# Optional. Used only for the yours (self) mode and the cross-entry
# patterns reader. Those paths carry the heaviest voice-safety rules
# (crisis refusal, no-psychologizing voice) and benefit from a stronger
# model. Falls back to OPENROUTER_MODEL when unset.
# Suggested: anthropic/claude-opus-4.7
OPENROUTER_SELF_MODEL=

# Direct Anthropic — used only if OPENROUTER_API_KEY is not set.
ANTHROPIC_API_KEY=

# Optional. Chrome Web Store listing URL for the Lenss companion
# extension. When set, the homepage footer renders a small
# "Lenss for ChatGPT and Claude →" link and `/extension` 302s to
# this URL. When unset, the link is hidden and `/extension` 404s.
# Fill in after the CWS submission is approved.
NEXT_PUBLIC_EXTENSION_CWS_URL=
