# Either of these unlocks real model output. Without one, the app
# returns hand-crafted mock readings so the UI works offline.

# OpenRouter — gateway to many providers under one key.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model for reveal and compare. Can be any OpenRouter model id,
# including the ":free" tier. Defaults to anthropic/claude-sonnet-4.5
# if unset.
OPENROUTER_MODEL=

# Optional. Used only for the yours (self) mode and the cross-entry
# patterns reader. Those paths carry the heaviest voice-safety rules
# (crisis refusal, no-psychologizing voice) and benefit from a stronger
# model. Falls back to OPENROUTER_MODEL when unset.
# Suggested: anthropic/claude-opus-4.7
OPENROUTER_SELF_MODEL=

# Direct Anthropic — used only if OPENROUTER_API_KEY is not set.
ANTHROPIC_API_KEY=

# Optional. Chrome Web Store listing URL for the Lenss companion
# extension. When set, the homepage footer renders a small
# "Lenss for ChatGPT and Claude →" link and `/extension` 302s to
# this URL. When unset, the link is hidden and `/extension` 404s.
# Fill in after the CWS submission is approved.
NEXT_PUBLIC_EXTENSION_CWS_URL=

# Postgres connection string. Required for /send-check (Lens Draft Check)
# user accounts, personas, history, and rate limiting. Recommend Neon
# free tier (https://neon.tech) — no credit card, generous limits, edge-
# compatible. Format:
#   postgresql://user:pass@ep-name.region.aws.neon.tech/dbname?sslmode=require
# After setting, run `npm run db:migrate` to create the schema.
DATABASE_URL=

# Salt for hashing anonymous-visitor IPs (first-free-check throttle on
# /send-check). Any random string, ~32+ chars. Generate with:
#   openssl rand -hex 32
ANON_IP_HASH_SALT=

# Payment provider. Switches /account UI + checkout flow.
#   stripe   — uses Stripe Checkout (requires Stripe India activation)
#   razorpay — uses Razorpay Subscriptions (India-friendly, no entity required)
# Defaults to "razorpay" when unset.
PAYMENT_PROVIDER=razorpay

# Client-visible mirror of PAYMENT_PROVIDER. Must match. Needed because the
# /account page picks endpoints + cancel UX (portal vs inline confirm) based
# on provider. Keep both in sync.
NEXT_PUBLIC_PAYMENT_PROVIDER=razorpay

# Master kill-switch for the paid tier UI. When "false", all upgrade /
# "Stay on Pro" / restart buttons are disabled with a "Subscriptions open
# soon" message. Free signup + trial still work. Flip to "true" the day
# Razorpay activation completes and webhook is wired.
NEXT_PUBLIC_PAYMENTS_LIVE=false

# Razorpay — required when PAYMENT_PROVIDER=razorpay.
# Get test keys at https://dashboard.razorpay.com/app/keys
# Plan id is created at Subscriptions → Plans (₹1599/mo).
# Webhook secret is set when you add the webhook endpoint at
# https://dashboard.razorpay.com/app/webhooks
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=
